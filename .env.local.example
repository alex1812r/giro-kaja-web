# Copia a .env.local y completa con las claves de tu proyecto Supabase.
# Dashboard: Project Settings → API

# Cliente (navegador / SSR). "Publishable" o "anon public".
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Solo servidor (opcional por ahora; necesario para admin más adelante).
# No usar prefijo NEXT_PUBLIC_. No commitear valores reales.
SUPABASE_SERVICE_ROLE_KEY=your-secret-or-service-role-key
